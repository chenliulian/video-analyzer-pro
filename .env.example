# LLM API 配置
# 复制此文件为 .env 并填入你的实际配置

# ===== LLM 配置（用于文本精炼）=====

# API密钥（必填）
LLM_API_KEY=your-api-key-here

# API地址（可选，默认为OpenAI官方地址）
# 如果使用第三方服务（如DeepSeek、通义千问等），需要填写对应的base_url
# 示例：
# OpenAI官方: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com
# 智谱AI: https://open.bigmodel.cn/api/paas/v4
LLM_BASE_URL=https://api.openai.com/v1

# 模型名称（可选，默认为gpt-4）
# 根据使用的服务选择对应模型
# 示例：
# OpenAI: gpt-4, gpt-3.5-turbo
# DeepSeek: deepseek-chat, deepseek-coder
# 智谱AI: glm-4, glm-3-turbo
LLM_MODEL=gpt-4

# ===== OCR 配置（通义千问多模态）=====

# 阿里云通义千问 API Key（用于OCR识别）
# 获取地址: https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# OCR模型选择（可选，默认为 qwen-vl-max）
# qwen-vl-max: 最强识别能力（推荐）
# qwen-vl-plus: 平衡性能和成本
# qwen3-vl-plus: 最新版本
QWEN_OCR_MODEL=qwen-vl-max

# ===== 推荐配置示例 =====

# 方案1: DeepSeek + 通义千问（推荐，性价比最高）
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# 方案2: 智谱AI + 通义千问（国内访问快）
# LLM_API_KEY=xxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# 方案3: OpenAI + 通义千问（效果最好）
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

